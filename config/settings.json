{
  "systemInstruction": {
    "file": "HOME_DIR_PLACEHOLDER/.gemini/system_prompt.md"
  },
  "approvals": "auto",
  "permissions": {
    "trustedDirectories": [
      "HOME_DIR_PLACEHOLDER/colcon_ws/src"
    ]
  },
  "workspace": {
    "defaultDirectory": "HOME_DIR_PLACEHOLDER/colcon_ws/src"
  },
  "mcp": {
    "autoApprove": [
      "github",
      "context7",
      "playwright",
      "googledbt"
    ]
  },
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_TOKEN_HERE"
      }
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "googledbt": {
      "command": "npx",
      "args": [
        "-y",
        "@google/chrome-devtools-mcp"
      ]
    }
  }
}