{
  "systemInstruction": {
    "file": "~/.gemini/system_prompt.md"
  },
  "approvals": "auto",
  "permissions": {
    "trustedDirectories": [
      "~/colcon_ws/src"
    ]
  },
  "workspace": {
    "defaultDirectory": "~/colcon_ws/src"
  },
  "mcp": {
    "autoApprove": [
      "github"
    ]
  },
  "mcpServers": {
    "github": {
      "command": "npm",
      "args": [
        "exec",
        "-y",
        "--",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_TOKEN_HERE"
      }
    }
  }
}